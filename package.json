{
    "$schema": "https://www.schemastore.org/package.json",
    "name": "easy-market",
    "version": "1.0.0",
    "description": "Application desktop EasyMarket.",
    "author": "EasyMarket",
    "private": true,
    "type": "module",
    "main": "electron/main.cjs",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "mobile:sync": "cap sync android",
        "mobile:open": "cap open android",
        "mobile:release": "cd android && gradlew.bat assembleRelease",
        "desktop:dev": "electron .",
        "desktop:build": "electron-builder --win nsis --x64"
    },
    "build": {
        "appId": "com.easymarket.desktop",
        "productName": "EasyMarket",
        "directories": {
            "output": "desktop-dist"
        },
        "files": [
            "electron/**/*"
        ],
        "extraResources": [
            {
                "from": "public/icons/logo.png",
                "to": "icons/logo.png"
            }
        ],
        "win": {
            "icon": "build/icon.ico",
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ]
        },
        "nsis": {
            "installerIcon": "build/icon.ico",
            "uninstallerIcon": "build/icon.ico",
            "oneClick": false,
            "perMachine": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "EasyMarket"
        }
    },
    "devDependencies": {
        "@capacitor/cli": "^8.3.4",
        "@tailwindcss/vite": "^4.0.0",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "electron": "^42.2.0",
        "electron-builder": "^26.8.1",
        "laravel-vite-plugin": "^2.0.0",
        "tailwindcss": "^4.0.0",
        "vite": "^7.0.7"
    },
    "dependencies": {
        "@capacitor/android": "^8.3.4",
        "@capacitor/core": "^8.3.4",
        "@vitejs/plugin-vue": "^6.0.7",
        "vue": "^3.5.34"
    }
}
